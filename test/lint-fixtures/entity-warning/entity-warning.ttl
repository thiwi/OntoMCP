@prefix ew: <http://example.com/entity-warning#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ew:ChainClass a owl:Class ;
  rdfs:label "Chain Class" ;
  rdfs:comment "Class used to trigger entity-level property chain warning." ;
  owl:propertyChainAxiom ( ew:edgeA ew:edgeB ) .

ew:name a owl:DatatypeProperty ;
  rdfs:label "name" ;
  rdfs:comment "Name for the entity." .

ew:ChainClassShape a sh:NodeShape ;
  sh:targetClass ew:ChainClass ;
  sh:property [
    sh:path ew:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] .
