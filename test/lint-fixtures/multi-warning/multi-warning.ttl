@prefix mw: <http://example.com/multi-warning#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mw:Root a owl:Class ;
  rdfs:label "Root" .

mw:Target a owl:Class ;
  rdfs:label "Target" .

mw:badProp a owl:ObjectProperty ;
  rdfs:label "bad prop" ;
  owl:propertyChainAxiom ( mw:left mw:right ) .

mw:badPropB a owl:ObjectProperty ;
  rdfs:label "bad prop b" ;
  owl:propertyChainAxiom ( mw:left2 mw:right2 ) .

mw:RootShape a sh:NodeShape ;
  sh:targetClass mw:Root ;
  sh:property [
    sh:path mw:badProp ;
    sh:class mw:Target ;
    sh:minCount 2 ;
    sh:maxCount 1
  ] ;
  sh:property [
    sh:path mw:badPropB ;
    sh:class mw:Target ;
    sh:minCount 0 ;
    sh:maxCount 1
  ] .

mw:TargetShape a sh:NodeShape ;
  sh:targetClass mw:Target ;
  sh:property [
    sh:path mw:id ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1
  ] .
